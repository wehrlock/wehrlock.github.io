---
import Base from '@layouts/Base.astro';
import WhirlyViewer from '@components/WhirlyViewer.astro';
import DesignNav from '@components/DesignNav.astro';

const designs = [
  { name: "Wehrlock", id: "wehrlock" },
  { name: "Eye Stars", id: "eye-stars" },
  { name: "Stirry Starry", id: "stirry-starry" },
  { name: "Hexxy Haxxy", id: "hexxy-haxxy" },
];

export function getStaticPaths() {
  return [
    { params: { design: "wehrlock" } },
    { params: { design: "eye-stars" } },
    { params: { design: "stirry-starry" } },
    { params: { design: "hexxy-haxxy" } },
  ];
}

const { design } = Astro.params;
const current = designs.find(d => d.id === design)!;
---
<Base title={`Whirly — ${current.name}`}>
  <article class="container mx-auto max-w-prose py-8 px-4">
    <h1 class="text-3xl font-bold tracking-wide text-center mb-8">Wehrle Whirly</h1>
    <WhirlyViewer initialDesign={design} />
    <div class="mt-8">
      <DesignNav currentDesign={design} />
    </div>
  </article>
</Base>
