---
import Base from '@layouts/Base.astro';
import data from '@data/profiles.json';
const person = data.anna;
const profiles = Object.entries(person.profiles || {});
---
<Base title={person.name + " Wehrle"}>
  <article class="container mx-auto max-w-prose py-8 px-4">
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden max-w-md mx-auto">
      <div class="bg-gradient-to-r from-blue-500 to-cyan-500 h-24"></div>
      <div class="px-6 pb-6 relative">
        <div class="h-20 w-20 rounded-full bg-gray-200 border-4 border-white mx-auto -mt-10 flex items-center justify-center text-gray-500 text-3xl font-bold uppercase shadow-sm">
          {person.name.charAt(0)}
        </div>
        <div class="text-center mt-4 mb-6">
          <h1 class="text-3xl font-bold text-gray-800">{person.name} Wehrle</h1>
        </div>
        
        {profiles.length > 0 ? (
          <div>
            <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3 text-center">Profiles & Links</h2>
            <div class="grid grid-cols-1 gap-3">
              {profiles.map(([name, url]) => (
                <a href={url} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-full py-2.5 px-4 border border-gray-200 shadow-sm rounded-lg hover:bg-blue-50 hover:border-blue-300 hover:text-blue-700 transition-all duration-200 text-blue-600 font-medium text-sm">
                  {name}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <div class="text-center text-gray-500 bg-gray-50 rounded-lg p-6 border border-gray-100 border-dashed">
            <p class="text-sm">No profiles currently linked.</p>
          </div>
        )}
      </div>
    </div>
  </article>
</Base>
