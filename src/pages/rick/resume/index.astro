---
import Base from '@layouts/Base.astro';
import diploma from '@assets/rick/diploma.jpg';
---
<Base title="Rick Wehrle's Resume">
  <article class="container mx-auto max-w-prose py-8 px-4">
    <section class="bg-white rounded-xl shadow-lg border border-gray-100 p-8">
      <h1 class="text-4xl font-bold text-gray-800 mb-2">Rick Wehrle</h1>
      <address class="text-gray-600 mb-8 not-italic">
        9720 Winter Way<br />
        Zionsville, IN 46077<br />
      </address>
      
      <h2 class="text-2xl font-bold text-gray-800 mt-8 mb-4 border-b-2 border-blue-500 pb-2">Education</h2>
      <div class="mb-6">
        <h3 class="text-lg font-semibold text-gray-800"><a href="https://www.purdue.edu/" class="text-blue-500 hover:underline">Purdue University</a></h3>
        <p class="text-gray-700">Bachelor of Science in <a href="https://www.cs.purdue.edu/" class="text-blue-500 hover:underline">Computer Science</a></p>
        <p class="text-gray-600 text-sm">Minors: <a href="https://hhs.purdue.edu/psy/" class="text-blue-500 hover:underline">Psychology</a> and <a href="https://www.math.purdue.edu/" class="text-blue-500 hover:underline">Mathematics</a></p>
        <p class="text-gray-600 text-sm">May 1997 <a href={diploma.src} class="text-blue-500 hover:underline">(Diploma)</a></p>
      </div>
      
      <h2 class="text-2xl font-bold text-gray-800 mt-8 mb-4 border-b-2 border-blue-500 pb-2">Experience</h2>
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold text-gray-800"><a href="https://www.murraymentor.ai/" class="text-blue-500 hover:underline">Murray Mentor</a></h3>
          <p class="text-gray-700">Senior Software Engineer</p>
          <p class="text-gray-600 text-sm">August 2025 to Present</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800">CarSnoop</h3>
          <p class="text-gray-700">Chief Technology Officer</p>
          <p class="text-gray-600 text-sm">May 2023 to August 2025</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800"><a href="https://powderkeg.com/" class="text-blue-500 hover:underline">Powderkeg</a></h3>
          <p class="text-gray-700">Chief Technology Officer</p>
          <p class="text-gray-600 text-sm">May 2021 to May 2023</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800">Vertex Intelligence</h3>
          <p class="text-gray-700">Senior Software Architect</p>
          <p class="text-gray-600 text-sm">July 2020 to May 2021</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800">Clear Software</h3>
          <p class="text-gray-700">Solutions Architect</p>
          <p class="text-gray-600 text-sm">February 2020 to July 2020</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800">Work Here LLC</h3>
          <p class="text-gray-700">Chief Technology Officer</p>
          <p class="text-gray-600 text-sm">June 2015 to February 2020</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800"><a href="https://directemployers.org/" class="text-blue-500 hover:underline">DirectEmployers Association</a></h3>
          <p class="text-gray-700">Vice President of Product Development</p>
          <p class="text-gray-600 text-sm">August 2008 to June 2015</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800"><a href="https://www.monster.com/" class="text-blue-500 hover:underline">Monster Worldwide</a></h3>
          <p class="text-gray-700">Vice President of Global Site Analytics</p>
          <p class="text-gray-600 text-sm">August 2007 to August 2008</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800"><a href="https://www.vistaprint.com/" class="text-blue-500 hover:underline">VistaPrint</a></h3>
          <p class="text-gray-700">Director Channel Analytics</p>
          <p class="text-gray-600 text-sm">May 2007 to August 2007</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800"><a href="https://www.monster.com/" class="text-blue-500 hover:underline">Monster Worldwide</a></h3>
          <p class="text-gray-700">Vice President of Information Services</p>
          <p class="text-gray-600 text-sm">May 1997 to May 2007</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800">Indiana Higher Education Telecommunication System</h3>
          <p class="text-gray-700">Network Information Coordinator</p>
          <p class="text-gray-600 text-sm">November 1994 to April 1997</p>
        </div>
        
        <div>
          <h3 class="text-lg font-semibold text-gray-800">Online Career Center</h3>
          <p class="text-gray-700">Internet Consultant</p>
          <p class="text-gray-600 text-sm">May 1994 to May 1997</p>
        </div>
      </div>
    </section>
  </article>
</Base>
