---
import Base from '@layouts/Base.astro';
import ProfileCard from '@components/ProfileCard.astro';
import profile_image from '@assets/rick/avatar.jpg';
import data from '@data/profiles.json';
const person = data.rick;
const fullName = person.givenName + " " + person.familyName;
---
<Base title={fullName}>
  <article class="container mx-auto max-w-prose py-8 px-4">
    <ProfileCard
      person={person}
      avatarType="picture"
      avatarImage={profile_image}
    />
  </article>
</Base>

