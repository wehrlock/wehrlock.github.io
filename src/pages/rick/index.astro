---
import Base from '@layouts/Base.astro';
import ProfileCard from '@components/ProfileCard.astro';
import profile_image from '@assets/rick/rick-green-bg.jpg';
import data from '@data/profiles.json';
const person = data.rick;
---
<Base title={person.name + " Wehrle"}>
  <article class="container mx-auto max-w-prose py-8 px-4">
    <ProfileCard 
      person={person} 
      avatarType="picture" 
      avatarImage={profile_image}
      includeResumeLink={true}
    />
  </article>
</Base>

