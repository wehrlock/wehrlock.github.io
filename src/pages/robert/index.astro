---
import Base from '@layouts/Base.astro';
import ProfileCard from '@components/ProfileCard.astro';
import avatar_image from '@assets/robert/avatar.jpg';
import data from '@data/profiles.json';
const person = data.robert;
const fullName = person.name + " " + person.familyName;
---
<Base title={fullName}>
  <article class="container mx-auto max-w-prose py-8 px-4">
    <ProfileCard 
      person={person} 
      avatarType="picture"
      avatarImage={avatar_image}
    />
  </article>
</Base>
