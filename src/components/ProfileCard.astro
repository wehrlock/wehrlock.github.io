---
import { Picture, type ImageMetadata } from 'astro:assets';

interface Props {
  person: {
    name: string;
    familyName: string;
    profiles?: Record<string, string>;
    resume?: boolean;
  };
  avatarType: 'picture' | 'initial';
  avatarImage?: ImageMetadata;
  coverImage?: ImageMetadata;
}

const {
  person,
  avatarType,
  avatarImage,
  coverImage,
} = Astro.props;

const fullName = `${person.name} ${person.familyName}`;
const includeResumeLink = !!person.resume;

const profiles = Object.entries(person.profiles || {});
---

<div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden max-w-md mx-auto">
  {/* Header Section */}
  {coverImage ? (
    <div class="h-48 relative overflow-hidden">
      <Picture src={coverImage} alt={fullName} class="w-full h-full object-cover object-center" priority />
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
    </div>
  ) : (
    <div class="bg-gradient-to-r from-blue-500 to-cyan-500 h-24"></div>
  )}

  {/* Content Section */}
  <div class="px-6 pb-6 relative">
    {/* Avatar */}
    <div class={`rounded-full border-4 border-white mx-auto ${coverImage ? '-mt-10' : '-mt-14'} flex items-center justify-center shadow-sm overflow-hidden ${avatarType === 'picture' ? 'h-28 w-28 bg-white' : 'h-20 w-20 bg-gray-200 text-gray-500 text-3xl font-bold uppercase'}`}>
      {avatarType === 'picture' ? (
        avatarImage && <Picture src={avatarImage} alt={person.name} class="w-full h-full object-cover" />
      ) : (
        person.name.charAt(0)
      )}
    </div>

    {/* Name */}
    <div class="text-center mt-4 mb-6">
      <h1 class="text-3xl font-bold text-gray-800">{fullName}</h1>
    </div>

    {/* Links Section */}
    {(includeResumeLink || profiles.length > 0) ? (
      <div>
        <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-3 text-center">Profiles & Links</h2>
        <div class="grid grid-cols-1 gap-3">
          {includeResumeLink && (
            <a href={`/${person.name.toLowerCase()}/resume/`} class="flex items-center justify-center w-full py-2.5 px-4 border border-blue-500 bg-blue-50 shadow-sm rounded-lg hover:bg-blue-100 transition-all duration-200 text-blue-700 font-bold text-sm">
              My Resume
            </a>
          )}
          {profiles.map(([name, url]) => (
            <a href={url} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-full py-2.5 px-4 border border-gray-200 shadow-sm rounded-lg hover:bg-blue-50 hover:border-blue-300 hover:text-blue-700 transition-all duration-200 text-blue-600 font-medium text-sm">
              {name}
            </a>
          ))}
        </div>
      </div>
    ) : (
      <div class="text-center text-gray-500 bg-gray-50 rounded-lg p-6 border border-gray-100 border-dashed">
        <p class="text-sm">No profiles currently linked.</p>
      </div>
    )}
  </div>
</div>
