---
interface Props {
  initialDesign?: string;
}
const { initialDesign = "eye-stars" } = Astro.props;
---

<div class="flex flex-col items-center gap-8 w-full max-w-lg mx-auto" id="whirly-viewer" data-initial-design={initialDesign}>
  <div class="relative">
    <div
      id="whirly-svg-container"
      class="w-72 h-72 sm:w-80 sm:h-80 flex items-center justify-center"
    ></div>
    <button
      id="fullscreen-btn"
      class="absolute top-2 right-2 w-8 h-8 rounded border border-gray-500 text-gray-400 flex items-center justify-center hover:border-gray-300 hover:bg-gray-700 transition-colors"
      aria-label="Toggle Fullscreen"
      title="Toggle Fullscreen"
    ><svg id="fs-expand" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg><svg id="fs-compress" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 14 10 14 10 20"/><polyline points="20 10 14 10 14 4"/><line x1="14" y1="10" x2="21" y2="3"/><line x1="3" y1="21" x2="10" y2="14"/></svg></button>
  </div>

  <div class="flex items-center gap-3">
    <button
      id="rps-down"
      class="w-9 h-9 rounded-full border-2 border-gray-500 text-gray-400 text-lg flex items-center justify-center hover:border-gray-300 hover:bg-gray-700 transition-colors"
      aria-label="Decrease RPS"
      title="Decrease RPS"
    >&larr;</button>
    <button
      id="spin-left-btn"
      class="w-9 h-9 rounded-full border-2 border-gray-500 text-gray-400 text-lg flex items-center justify-center hover:border-gray-300 hover:bg-gray-700 transition-colors"
      aria-label="Spin Left with Decay"
      title="Spin Left with Decay"
    >&olarr;</button>
    <button
      id="stop-btn"
      class="w-9 h-9 rounded-full border-2 border-gray-500 text-gray-400 text-sm flex items-center justify-center hover:border-gray-300 hover:bg-gray-700 transition-colors"
      aria-label="Stop Spinning"
      title="Stop Spinning"
    ><svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><rect x="4" y="4" width="16" height="16" rx="2"/></svg></button>
    <button
      id="spin-right-btn"
      class="w-9 h-9 rounded-full border-2 border-gray-500 text-gray-400 text-lg flex items-center justify-center hover:border-gray-300 hover:bg-gray-700 transition-colors"
      aria-label="Spin Right with Decay"
      title="Spin Right with Decay"
    >&orarr;</button>
    <button
      id="rps-up"
      class="w-9 h-9 rounded-full border-2 border-gray-500 text-gray-400 text-lg flex items-center justify-center hover:border-gray-300 hover:bg-gray-700 transition-colors"
      aria-label="Increase RPS"
      title="Increase RPS"
    >&rarr;</button>
  </div>

  <div class="flex items-center gap-3">
    <span id="rps-display" class="tabular-nums text-sm min-w-[7ch] text-center text-gray-400">0.50 rps</span>
  </div>

</div>

<style>
  #whirly-viewer:fullscreen {
    background: black;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    max-width: 100%;
    padding: 1rem;
  }
  #whirly-viewer:fullscreen #whirly-svg-container {
    width: 80vh;
    height: 80vh;
    max-width: 100vw;
  }
</style>

<script>
  const designs = [
    { name: "Eye Stars", file: "/whirly/eye-stars-animated.svg", id: "eye-stars" },
    { name: "Hexxy Haxxy", file: "/whirly/hexxy-haxxy-animated.svg", id: "hexxy-haxxy" },
    { name: "Stirry Starry", file: "/whirly/stirry-starry-animated.svg", id: "stirry-starry" },
  ];

  const viewer = document.getElementById("whirly-viewer")!;
  const initialDesign = viewer.dataset.initialDesign || "eye-stars";
  const container = document.getElementById("whirly-svg-container")!;
  const display = document.getElementById("rps-display")!;
  const btnUp = document.getElementById("rps-up")!;
  const btnDown = document.getElementById("rps-down")!;
  const btnSpinRight = document.getElementById("spin-right-btn")!;
  const btnSpinLeft = document.getElementById("spin-left-btn")!;
  const btnStop = document.getElementById("stop-btn")!;
  const btnFullscreen = document.getElementById("fullscreen-btn")!;
  const fsExpand = document.getElementById("fs-expand")!;
  const fsCompress = document.getElementById("fs-compress")!;


  let rps = 0.5;
  let currentDesign: string | null = null;
  let decayTimer: number | null = null;
  let angle = 0;
  let lastFrame = performance.now();

  // Drive rotation manually so speed changes are seamless
  function rotationLoop(now: number) {
    const dt = (now - lastFrame) / 1000;
    lastFrame = now;
    if (rps !== 0) {
      angle = (angle + rps * 360 * dt) % 360;
    }
    const spinner = container.querySelector(".spinner") as SVGElement | null;
    if (spinner) {
      spinner.style.transform = `rotate(${angle}deg)`;
    }
    requestAnimationFrame(rotationLoop);
  }
  requestAnimationFrame(rotationLoop);

  function updateDisplay() {
    const prefix = rps < 0 ? "-" : "";
    display.textContent = prefix + Math.abs(rps).toFixed(2) + " rps";
  }

  async function loadDesign(file: string, id: string) {
    if (currentDesign === id) return;
    currentDesign = id;
    const res = await fetch(file);
    let svgText = await res.text();
    svgText = svgText.replace(/<\?xml[^?]*\?>/, "");
    container.innerHTML = svgText;
    const svg = container.querySelector("svg");
    if (svg) {
      if (!svg.getAttribute("viewBox")) {
        const w = svg.getAttribute("width")?.replace("px", "") || "500";
        const h = svg.getAttribute("height")?.replace("px", "") || "500";
        svg.setAttribute("viewBox", `0 0 ${w} ${h}`);
      }
      svg.removeAttribute("width");
      svg.removeAttribute("height");
      svg.classList.add("w-full", "h-full");
    }
    // Disable the CSS animation so we control rotation manually
    const spinner = container.querySelector(".spinner") as SVGElement | null;
    if (spinner) {
      spinner.style.animation = "none";
    }
    updateDisplay();
  }

  function stopDecay() {
    if (decayTimer !== null) {
      cancelAnimationFrame(decayTimer);
      decayTimer = null;
    }
  }

  btnUp.addEventListener("click", () => {
    stopDecay();
    rps = Math.ceil(rps * 4 + 0.001) / 4;
    updateDisplay();
  });

  btnDown.addEventListener("click", () => {
    stopDecay();
    rps = Math.floor(rps * 4 - 0.001) / 4;
    updateDisplay();
  });

  function startDecay() {
    stopDecay();
    rps = Math.max(rps, 0) + 2.0;
    updateDisplay();
    let last = performance.now();
    function tick(now: number) {
      const dt = (now - last) / 1000;
      last = now;
      rps = Math.max(0, rps - dt * 0.2);
      updateDisplay();
      if (rps > 0) {
        decayTimer = requestAnimationFrame(tick);
      } else {
        decayTimer = null;
      }
    }
    decayTimer = requestAnimationFrame(tick);
  }

  function startDecayLeft() {
    stopDecay();
    rps = Math.min(rps, 0) - 2.0;
    updateDisplay();
    let last = performance.now();
    function tick(now: number) {
      const dt = (now - last) / 1000;
      last = now;
      rps = Math.min(0, rps + dt * 0.2);
      updateDisplay();
      if (rps < 0) {
        decayTimer = requestAnimationFrame(tick);
      } else {
        decayTimer = null;
      }
    }
    decayTimer = requestAnimationFrame(tick);
  }

  btnSpinRight.addEventListener("click", startDecay);
  btnSpinLeft.addEventListener("click", startDecayLeft);

  btnStop.addEventListener("click", () => {
    stopDecay();
    rps = 0;
    angle = 0;
    const spinner = container.querySelector(".spinner") as SVGElement | null;
    if (spinner) {
      spinner.style.transform = `rotate(0deg)`;
    }
    updateDisplay();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "ArrowRight") {
      stopDecay();
      rps = Math.ceil(rps * 4 + 0.001) / 4;
      updateDisplay();
    } else if (e.key === "ArrowLeft") {
      stopDecay();
      rps = Math.floor(rps * 4 - 0.001) / 4;
      updateDisplay();
    }
  });

  btnFullscreen.addEventListener("click", () => {
    if (document.fullscreenElement) {
      document.exitFullscreen();
    } else {
      viewer.requestFullscreen();
    }
  });

  document.addEventListener("fullscreenchange", () => {
    const isFs = !!document.fullscreenElement;
    fsExpand.classList.toggle("hidden", isFs);
    fsCompress.classList.toggle("hidden", !isFs);
  });

  // Load design matching the route
  const initial = designs.find(d => d.id === initialDesign) || designs[0];
  loadDesign(initial.file, initial.id);
</script>
